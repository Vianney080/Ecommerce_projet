# Obligatoire sur Vercel (build) : sans cette variable, les images /uploads et l’API pointent vers localhost.
VITE_API_URL=https://votre-backend.onrender.com/api

# Optionnel — statistiques (laisser vide si non utilisé)
# Plausible : domaine du site tel qu’affiché dans le tableau de bord Plausible
# VITE_PLAUSIBLE_DOMAIN=cosmetishop.vercel.app
# Google Analytics 4 : ID de mesure G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
