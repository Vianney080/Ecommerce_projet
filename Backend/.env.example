PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/e_commerce_db
JWT_SECRET=changez_moi

# URL du front (liens dans les emails : suivi, etc.)
FRONTEND_URL=http://localhost:5173
# Optionnel : plusieurs origines autorisées pour CORS (domaine custom, etc.), séparées par des virgules
# CORS_ORIGINS=https://mon-site.com,https://www.mon-site.com
# Note : tout *.vercel.app est déjà autorisé automatiquement par le serveur.

# --- Emails (codes inscription / MDP / commandes) : choisir UNE des deux options ---
#
# Option A — RECOMMANDÉ sur Render gratuit : Resend (API HTTPS, port 443 ; le SMTP sortant est souvent bloqué sur l’hébergement gratuit).
# Compte sur https://resend.com → clé API → domaine ou expéditeur « onboarding@resend.dev » pour les tests.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=onboarding@resend.dev
#
# Option B — SMTP (Gmail, etc.) : fonctionne bien en local ; sur Render gratuit, connexion souvent en timeout (ports 587/465 bloqués).

# SMTP — Gmail : « mot de passe d'application » (sans espaces dans EMAIL_PASS / SMTP_PASS, ou avec espaces : le serveur les enlève)
# Deux noms possibles (équivalents) :
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
# ou bien :
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=votre.email@gmail.com
# EMAIL_PASS=xxxxxxxxxxxxxxxx
# Même adresse que EMAIL_USER (Gmail refuse souvent un autre From)
MAIL_FROM="CosmétiShop <votre.email@gmail.com>"

# Uniquement en développement : renvoie le code dans la réponse API (NE JAMAIS activer en production)
# EMAIL_DEV_AFFICHER_CODE=true
