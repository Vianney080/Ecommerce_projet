PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=remplacez_par_un_secret_tres_long_et_aleatoire
FRONTEND_URL=https://votre-frontend.vercel.app
# URL publique du backend (images /uploads/...). Sur Render, RENDER_EXTERNAL_URL suffit souvent.
# PUBLIC_API_ORIGIN=https://votre-api.onrender.com
# Optionnel: plusieurs origines separees par des virgules
# CORS_ORIGINS=https://votre-frontend.vercel.app,https://votre-deuxieme-domaine.com
# Dossier persistant pour /uploads (monter un Disk sur Render et mettre le chemin de montage ici).
# Sans cela ni Cloudinary, les fichiers sous ./uploads sont effaces au redeploiement.
# UPLOADS_DIR=/var/render/data/uploads
#
# Recommande en production (sinon /uploads est perdu a chaque redeploiement Render)
# Tableau de bord Cloudinary > Settings > Security : autoriser le type "Image", pas de restriction stricte en dev.
# CLOUDINARY_CLOUD_NAME=xxxx
# CLOUDINARY_API_KEY=xxxx
# CLOUDINARY_API_SECRET=xxxx
NODE_ENV=production
